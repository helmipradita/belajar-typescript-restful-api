# Application
APP_NAME=belajar-typescript-restful-api
NODE_ENV=development
PORT=3030

# Database
DATABASE_URL="mysql://root:@localhost:3306/belajar_typescript_restful_api"

# Redis — Wajib, sama seperti MySQL
REDIS_URL="redis://localhost:6379"

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
LOG_MAX_FILES=14d

# Request
BODY_LIMIT=1mb

# CORS
CORS_ORIGIN=*

# JWT
JWT_SECRET=rahasia-jwt-belajar-typescript-2024
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenTelemetry Tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=typescript-restful-api
OTEL_SDK_DISABLED=true

# Rate Limiting (Redis-based)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=60
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_API_MAX=500
RATE_LIMIT_API_WINDOW_MS=900000
