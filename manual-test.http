@baseUrl = http://localhost:3030
@bearerToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6ImVrbyIsIm5hbWUiOiJFa28gS3Vybmlhd2FuIiwiaWF0IjoxNzgxMjMwNDU3LCJleHAiOjE3ODEyMzEzNTd9.xJByMcTV1rWvhChnsmC09MxQj0Le4Sht0pSfNNlH4AE

### ====================================
### 1. REGISTER
### ====================================
POST {{baseUrl}}/api/v1/users
Content-Type: application/json
Accept: application/json

{
  "username": "eko",
  "password" : "eko123",
  "name" : "Eko"
}

### ====================================
### 2. LOGIN
### ====================================
### Copy access_token → paste ke variable @bearerToken di atas
POST {{baseUrl}}/api/v1/users/login
Content-Type: application/json
Accept: application/json

{
  "username": "eko",
  "password" : "eko123"
}

### ====================================
### 3. REFRESH TOKEN
### ====================================
POST {{baseUrl}}/api/v1/users/refresh
Content-Type: application/json
Accept: application/json

{
  "refresh_token": "uuid-dari-login"
}

### ====================================
### 4. GET USER
### ====================================
GET {{baseUrl}}/api/v1/users/current
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 5. UPDATE USER
### ====================================
PATCH {{baseUrl}}/api/v1/users/current
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "name" : "Eko Kurniawan"
}

### ====================================
### 6. LOGOUT
### ====================================
DELETE {{baseUrl}}/api/v1/users/current
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 7. CREATE CONTACT
### ====================================
### Catat contactId dari response buat dipakai di endpoint /contacts/:id
POST {{baseUrl}}/api/v1/contacts
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "first_name" : "Budi",
  "last_name" : "Khannedy",
  "email": "budi@example.com",
  "phone" : "089999999"
}

### ====================================
### 8. GET CONTACT
### ====================================
### Ganti 1 dengan contactId dari response create contact
GET {{baseUrl}}/api/v1/contacts/85387
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 9. UPDATE CONTACT
### ====================================
PUT {{baseUrl}}/api/v1/contacts/85387
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "first_name" : "Eko",
  "last_name" : "Khannedy",
  "email": "eko@example.com",
  "phone" : "089999999"
}

### ====================================
### 10. SEARCH CONTACT
### ====================================
GET {{baseUrl}}/api/v1/contacts?name=Eko&page=1&size=10
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 11. DELETE CONTACT
### ====================================
DELETE {{baseUrl}}/api/v1/contacts/85387
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 12. CREATE ADDRESS
### ====================================
### Catat addressId dari response
POST {{baseUrl}}/api/v1/contacts/85387/addresses
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "street" : "Jalan Merdeka",
  "city": "Jakarta",
  "province" : "DKI Jakarta",
  "country" : "Indonesia",
  "postal_code" : "13123"
}

### ====================================
### 13. GET ADDRESS
### ====================================
GET {{baseUrl}}/api/v1/contacts/85387/addresses/1
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 14. UPDATE ADDRESS
### ====================================
PUT {{baseUrl}}/api/v1/contacts/85387/addresses/1
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{bearerToken}}

{
  "street" : "Jalan Sudirman",
  "city": "Bandung",
  "province" : "Jawa Barat",
  "country" : "Indonesia",
  "postal_code" : "40123"
}

### ====================================
### 15. LIST ADDRESSES
### ====================================
GET {{baseUrl}}/api/v1/contacts/85387/addresses?page=1&size=10
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 16. DELETE ADDRESS
### ====================================
DELETE {{baseUrl}}/api/v1/contacts/85387/addresses/1
Accept: application/json
Authorization: Bearer {{bearerToken}}

### ====================================
### 17. HEALTH & METRICS
### ====================================
GET {{baseUrl}}/api/v1/healthz
GET {{baseUrl}}/api/v1/health
GET {{baseUrl}}/api/v1/metrics
